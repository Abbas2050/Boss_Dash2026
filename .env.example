# MT5 API Configuration (Production)
# In production, set this to your PHP backend URL
# Example: https://yourdomain.com/mt5_api.php
VITE_MT5_API_URL=

# Base backend URL (used for SignalR + backend API endpoints in dev/proxy bypass cases)
# Example: https://6cw9krcg-5001.inc1.devtunnels.ms
VITE_BACKEND_BASE_URL=

# CRM / wallet / AI secrets
VITE_API_URL=
VITE_API_VERSION=
VITE_API_TOKEN=
VITE_WALLET_URL=
VITE_WALLET_TOKEN=
WALLET_API_TOKEN=
OPENAI_API_KEY=

# Server-side GA4 settings (used by server.js/api.js/ga4.js)
# GA4_PROPERTY_ID=476328175
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional fallback: file path on server (not committed)
# GA4_KEY_FILE=/absolute/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# DEBUG_GA4=0

# Optional: If you want to override the default MT5 server settings
# These are already configured in mt5_api.php, but you can override them here
# MT5_SERVER=mt5.skylinkstrader.com:443
# MT5_LOGIN=1023
# MT5_BUILD=4330
