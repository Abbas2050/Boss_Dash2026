# MT5 API Configuration (Production)
# In production, set this to your PHP backend URL
# Example: https://yourdomain.com/mt5_api.php
VITE_MT5_API_URL=

# Base backend URL (used for SignalR + backend API endpoints in dev/proxy bypass cases)
# Example: https://api.skylinkscapital.com
VITE_BACKEND_BASE_URL=

# CRM / wallet / AI secrets
# Example: https://portal.skylinkscapital.com/rest/transactions
VITE_API_URL=
VITE_API_VERSION=
VITE_API_TOKEN=
VITE_WALLET_URL=
VITE_WALLET_TOKEN=
WALLET_API_TOKEN=
OPENAI_API_KEY=

# Server-side GA4 settings (used by server.js/api.js/ga4.js)
# GA4_PROPERTY_ID=476328175
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional fallback: file path on server (not committed)
# GA4_KEY_FILE=/absolute/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# DEBUG_GA4=0

# Server-side auth DB + JWT
# AUTH_DB_HOST=localhost
# AUTH_DB_PORT=3306
# AUTH_DB_NAME=bossdash_auth
# AUTH_DB_USER=bossdash_user
# AUTH_DB_PASSWORD=change_me
# AUTH_JWT_SECRET=replace_with_long_random_secret
# AUTH_JWT_EXPIRES_IN=12h
# AUTH_SEED_NAME=Abbas
# AUTH_SEED_EMAIL=abbas@skylinks.capital
# AUTH_SEED_PASSWORD=admin123

# DocuSign integration (FXBO approved application -> envelope send)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# DOCUSIGN_TEMPLATE_ID=
# DOCUSIGN_TEMPLATE_ROLE=Signer
# DOCUSIGN_EMAIL_SUBJECT=Please sign your application document
# DOCUSIGN_AUTH_BASE=account-d.docusign.com
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_BASE_URI=
# DOCUSIGN_FXBO_WEBHOOK_BEARER=
# DOCUSIGN_CONNECT_HMAC_SECRET=
# DOCUSIGN_AUTO_SYNC_ENABLED=false
# DOCUSIGN_AUTO_SYNC_INTERVAL_SECONDS=300
# DOCUSIGN_AUTO_SYNC_RUN_ON_START=true
# DOCUSIGN_SYNC_LOOKBACK_MINUTES=6

# Optional: If you want to override the default MT5 server settings
# These are already configured in mt5_api.php, but you can override them here
# MT5_SERVER=mt5.skylinkstrader.com:443
# MT5_LOGIN=1023
# MT5_BUILD=4330
