<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- PassThrough: keep Express error bodies (JSON) instead of IIS HTML pages -->
    <httpErrors existingResponse="PassThrough" />

    <!-- iisnode: forward matched requests to the Node.js process -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- URL Rewrite: send every request that is NOT a physical file to Express -->
    <!-- This ensures /assets/index.js, /skylinks.ico, etc. reach Express      -->
    <!-- Express then serves them from dist/ via express.static               -->
    <rewrite>
      <rules>
        <rule name="Route all non-file requests to Express" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Block direct browser access to sensitive server-side directories -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment=".git" />
          <add segment="src" />
          <add segment="auth" />
          <add segment="docusign" />
          <add segment="scripts" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
