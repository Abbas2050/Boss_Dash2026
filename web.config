<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!--
      PassThrough: IIS forwards the response from Node.js/Express as-is,
      including error status codes (4xx, 5xx) with JSON bodies.
      Without this, IIS replaces Express error responses with its own HTML pages.
    -->
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
